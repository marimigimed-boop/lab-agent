# Environment variables for mymed
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Application
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here
DEBUG=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mymed

# External Services
# TELEGRAM_BOT_TOKEN=your-telegram-token
# WHATSAPP_API_KEY=your-whatsapp-key

# AI
# ANTHROPIC_API_KEY=your-anthropic-key

# ── moimedlab agent ────────────────────────────────────────────────────────────
# Почта для чтения анализов
MAILRU_EMAIL=moimed23@mail.ru
# App Password из настроек mail.ru (НЕ основной пароль от почты)
MAILRU_PASSWORD=ваш_app_password_здесь
# Папка с письмами от лаборатории
MAILRU_FOLDER=dialab
# Куда отправлять интерпретации (обычно та же почта)
SEND_TO=moimed23@mail.ru
